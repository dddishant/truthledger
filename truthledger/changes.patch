+  const options = Array.from(collected.values());
+  if (hasClimateTopic(topic)) {
+    options.sort((a, b) => (a.type === 'company' ? 0 : 1) - (b.type === 'company' ? 0 : 1));
+  }
+  return options.slice(0, 7);
