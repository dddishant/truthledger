+async function fetchTavilySources(query: string, limit = 8): Promise<SourceDoc[]> {
+  if (!hasTavilyConfig()) return [];
+  const rows = await searchClaims(query, limit);
+  return rows
+    .map((r: any) => {
+      const text = (r.raw_content || r.content || r.snippet || '').replace(/\s+/g, ' ').trim();
+      const title = (r.title || r.url || 'Web source').replace(/\s+/g, ' ').trim();
+      const snippet = limitWords((r.snippet || text || '').replace(/\s+/g, ' '), 25);
+      if (!r.url || !text) return null;
+      return {
+        url: r.url,
+        title,
+        snippet,
+        text,
+        published_at: r.published_date,
+        source_name: 'Tavily'
+      } as SourceDoc;
+    })
+    .filter((d: SourceDoc | null): d is SourceDoc => Boolean(d));
+}
+
+function claimTypeFromSentence(sentence: string): ClaimType | null {
+  const s = sentence.toLowerCase();
+  if (/\b(commits? to|pledges? to|targets?|plans? to|aims? to|will|expects? to|guidance)\b/.test(s)) return 'commitment';
+  if (/\b(progress|on track|achieved|reported|grew|declined|missed|met|delivered|as of)\b/.test(s)) return 'progress';
+  if (/\b(revenue|profit|margin|eps|guidance|quarter|annual|growth)\b/.test(s)) return 'financial_metric';
+  if (/\b(lawsuit|settlement|regulator|compliance|fine|investigation)\b/.test(s)) return 'legal_regulatory';
+  if (/\b(breach|outage|recall|incident|downtime)\b/.test(s)) return 'incident_outage';
+  if (/\b(launch|launched|rolled out|feature|capability|product)\b/.test(s)) return 'product_feature';
+  if (/\b(according to|said|stated|told|announced)\b/.test(s)) return 'attribution_quote';
+  return null;
+}
+
+function baseConfidence(type: ClaimType, sourceName?: string) {
+  const sourceBoost = sourceName === 'Tavily' ? 0.03 : sourceName === 'Google News' ? 0.02 : 0;
+  const score: Record<ClaimType, number> = {
+    commitment: 0.82,
+    progress: 0.76,
+    factual_profile: 0.9,
+    product_feature: 0.7,
+    financial_metric: 0.75,
+    legal_regulatory: 0.73,
+    incident_outage: 0.72,
+    attribution_quote: 0.68
+  };
+  return Math.min(0.98, score[type] + sourceBoost);
+}
+
+function extractClaimsFromSources(args: {
+  entityName: string;
+  topic: string;
+  sources: SourceDoc[];
+  allowedTypes: Set<ClaimType>;
+  limit: number;
+}): ApiClaim[] {
+  const { entityName, topic, sources, allowedTypes, limit } = args;
+  const aliases = Array.from(
+    new Set(
+      [entityName, entityName.split(' ')[0]]
+        .map((s) => s.toLowerCase().replace(/\b(inc\.?|corp\.?|company|group|ltd\.?|plc)\b/g, '').trim())
+        .filter(Boolean)
+    )
+  );
+
+  const dedup = new Map<string, ApiClaim>();
+  const extractedAt = new Date().toISOString();
+
+  for (const source of sources) {
+    const sentences = splitSentences(source.text).slice(0, 20);
+    for (const sentenceRaw of sentences) {
+      const sentence = sentenceRaw.replace(/\s+/g, ' ').trim();
+      if (!sentence) continue;
+      if (!topicMatches(sentence, topic)) continue;
+      const lower = sentence.toLowerCase();
+      if (!aliases.some((a) => lower.includes(a) || source.title.toLowerCase().includes(a))) continue;
+
+      const type = claimTypeFromSentence(sentence);
+      if (!type || !allowedTypes.has(type)) continue;
+
+      const claimText = sentence.endsWith('.') ? sentence : `${sentence}.`;
+      const key = `${type}:${claimText.toLowerCase().replace(/\s+/g, ' ')}`;
+      const evidence: Evidence = {
+        url: source.url,
+        title: source.title,
+        snippet: limitWords(sentence, 25),
+        published_at: source.published_at,
+        source_name: source.source_name
+      };
+
+      if (!dedup.has(key)) {
+        dedup.set(key, {
+          id: `claim-${dedup.size + 1}`,
+          type,
+          text: claimText,
+          confidence: baseConfidence(type, source.source_name),
+          evidence: [evidence],
+          extracted_at: extractedAt
+        });
+      } else {
+        const existing = dedup.get(key)!;
+        if (!existing.evidence.some((e) => e.url === evidence.url)) {
+          existing.evidence.push(evidence);
+          existing.confidence = Math.min(0.98, existing.confidence + 0.04);
+        }
+      }
+
+      if (dedup.size >= limit) break;
+    }
+    if (dedup.size >= limit) break;
+  }
+
+  return Array.from(dedup.values()).slice(0, limit);
+}
+
+function buildProfileClaims(entityName: string, summary: WikiSummary | null, facts: WikidataFacts, includeProfileFacts: boolean): ApiClaim[] {
+  if (!includeProfileFacts) return [];
+  const extractedAt = new Date().toISOString();
+  const out: ApiClaim[] = [];
+  const sourceUrl = summary?.content_urls?.desktop?.page || (summary?.title ? `https://en.wikipedia.org/wiki/${encodeURIComponent(summary.title)}` : '');
+  const sourceTitle = summary?.title || entityName;
+
+  if (summary?.description) {
+    out.push({
+      id: 'profile-1',
+      type: 'factual_profile',
+      text: `${sourceTitle} is ${summary.description}.`,
+      confidence: 0.9,
+      evidence: [{ url: sourceUrl, title: sourceTitle, snippet: limitWords(summary.extract || summary.description, 25), source_name: 'Wikipedia' }],
+      extracted_at: extractedAt
+    });
+  }
+  if (facts.inception) {
+    out.push({
+      id: 'profile-2',
+      type: 'factual_profile',
+      text: `${sourceTitle} was founded in ${facts.inception}.`,
+      confidence: 0.95,
+      evidence: [{ url: `https://www.wikidata.org/wiki/${summary?.wikibase_item || ''}`, title: sourceTitle, snippet: limitWords(`Founded: ${facts.inception}`, 25), source_name: 'Wikidata' }],
+      extracted_at: extractedAt,
+      normalized: { date: facts.inception }
+    });
+  }
+  if (facts.hq) {
+    out.push({
+      id: 'profile-3',
+      type: 'factual_profile',
+      text: `${sourceTitle} is headquartered in ${facts.hq}.`,
+      confidence: 0.95,
+      evidence: [{ url: `https://www.wikidata.org/wiki/${summary?.wikibase_item || ''}`, title: sourceTitle, snippet: limitWords(`Headquarters: ${facts.hq}`, 25), source_name: 'Wikidata' }],
+      extracted_at: extractedAt
+    });
+  }
+  if (facts.website) {
+    out.push({
+      id: 'profile-4',
+      type: 'factual_profile',
+      text: `${sourceTitle}'s official website is ${facts.website}.`,
+      confidence: 0.95,
+      evidence: [{ url: `https://www.wikidata.org/wiki/${summary?.wikibase_item || ''}`, title: sourceTitle, snippet: limitWords(`Website: ${facts.website}`, 25), source_name: 'Wikidata' }],
+      extracted_at: extractedAt
+    });
+  }
+
+  return out;
+}
