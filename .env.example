# Core app
NEXT_PUBLIC_APP_URL=http://localhost:4010

# Optional Neo4j (if you migrate graph/storage to Neo4j)
NEO4J_URI=bolt://host:7687
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=
NEO4J_DATABASE=neo4j

# Optional persistence database (if omitted app falls back to in-memory mock)
DATABASE_URL=postgresql://user:password@host:5432/autonomous_memory

# Required for /api/scan AI extraction
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini

# Required for /api/voice
MODULATE_API_KEY=
MODULATE_BASE_URL=https://api.modulate.ai
MODULATE_ANALYZE_PATH=/analyze

# Optional for web evidence search integrations
TAVILY_API_KEY=
YUTORI_API_KEY=
YUTORI_BASE_URL=https://yutori.com/scouts
